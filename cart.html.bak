<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cart — Soak Ops</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --lime: #C8FF00;
    --pink: #E5007D;
    --dark: #0D0D1A;
    --white: #FFFFFF;
    --gray: #6B7280;
    --light: #F4F4F5;
  }
  html { scroll-behavior: smooth; }
  body { font-family: 'Inter', sans-serif; background: var(--white); color: var(--dark); overflow-x: hidden; }

  .blob-tr { position: fixed; top: -140px; right: -140px; width: 700px; height: 700px; background: radial-gradient(circle, rgba(200,255,0,.15) 0%, transparent 65%); pointer-events: none; z-index: 0; }
  .blob-bl { position: fixed; bottom: -100px; left: -100px; width: 560px; height: 560px; background: radial-gradient(circle, rgba(150,220,255,.2) 0%, transparent 65%); pointer-events: none; z-index: 0; }

  /* NAV */
  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: space-between; align-items: center;
    padding: 16px 52px;
    background: rgba(255,255,255,.94);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(0,0,0,.07);
  }
  .logo {
    font-size: 20px; font-weight: 900; letter-spacing: -.04em;
    color: var(--dark); text-decoration: none;
    display: flex; align-items: center; gap: 8px;
  }
  .logo-icon { width: 26px; height: 26px; }
  .logo span.ops { color: var(--lime); text-shadow: 0 0 16px rgba(200,255,0,.5); }
  .nav-links { display: flex; gap: 32px; list-style: none; }
  .nav-links a { font-size: 12px; font-weight: 600; letter-spacing: .07em; text-transform: uppercase; color: var(--dark); text-decoration: none; transition: opacity .2s; }
  .nav-links a:hover { opacity: .5; }
  .cart-badge {
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--pink); color: #fff; font-size: 10px; font-weight: 800;
    width: 18px; height: 18px; border-radius: 50%; margin-left: 4px; vertical-align: middle;
  }
  .btn-nav { padding: 11px 24px; background: var(--dark); color: var(--white); font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; border: none; cursor: pointer; transition: opacity .2s; }
  .btn-nav:hover { opacity: .8; }

  /* PAGE */
  .page-wrap {
    max-width: 1100px; margin: 0 auto; padding: 120px 24px 80px;
    position: relative; z-index: 1;
  }
  .page-title {
    font-size: clamp(32px, 5vw, 56px); font-weight: 900; letter-spacing: -.03em;
    text-transform: uppercase; margin-bottom: 8px;
  }
  .page-title .k { color: var(--pink); }
  .page-subtitle { font-size: 14px; color: var(--gray); margin-bottom: 48px; }

  /* CART LAYOUT */
  .cart-layout { display: grid; grid-template-columns: 1fr 360px; gap: 40px; align-items: start; }
  @media (max-width: 800px) { .cart-layout { grid-template-columns: 1fr; } }

  /* CART ITEMS */
  .cart-items { display: flex; flex-direction: column; gap: 16px; }

  .cart-item {
    display: grid; grid-template-columns: 80px 1fr auto;
    gap: 16px; align-items: center;
    padding: 20px; border: 1.5px solid rgba(0,0,0,.08);
    background: var(--white);
    transition: border-color .2s;
  }
  .cart-item:hover { border-color: var(--lime); }
  .cart-item-img {
    width: 80px; height: 80px; object-fit: cover; display: block;
    background: var(--light);
  }
  .cart-item-name {
    font-size: 14px; font-weight: 800; letter-spacing: -.01em;
    text-transform: uppercase; margin-bottom: 6px;
  }
  .cart-item-name .k { color: var(--pink); }
  .cart-item-price { font-size: 16px; font-weight: 900; color: var(--dark); }

  .qty-row { display: flex; align-items: center; gap: 10px; margin-top: 10px; }
  .qty-btn {
    width: 30px; height: 30px; border: 1.5px solid var(--dark); background: transparent;
    font-size: 16px; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background .2s, color .2s;
  }
  .qty-btn:hover { background: var(--dark); color: var(--white); }
  .qty-val { font-size: 14px; font-weight: 800; min-width: 24px; text-align: center; }

  .remove-btn {
    background: none; border: none; cursor: pointer; color: var(--gray);
    font-size: 12px; font-weight: 600; letter-spacing: .05em; text-transform: uppercase;
    padding: 6px 0; transition: color .2s; align-self: start;
  }
  .remove-btn:hover { color: var(--pink); }

  /* EMPTY STATE */
  .empty-cart {
    text-align: center; padding: 80px 24px;
    border: 2px dashed rgba(0,0,0,.1);
  }
  .empty-cart .big { font-size: 48px; margin-bottom: 16px; }
  .empty-cart h2 { font-size: 22px; font-weight: 900; text-transform: uppercase; margin-bottom: 8px; }
  .empty-cart p { font-size: 14px; color: var(--gray); margin-bottom: 28px; }
  .btn-shop {
    display: inline-block; padding: 14px 36px;
    background: var(--lime); color: var(--dark);
    font-size: 13px; font-weight: 800; letter-spacing: .07em; text-transform: uppercase;
    text-decoration: none; transition: opacity .2s;
  }
  .btn-shop:hover { opacity: .85; }

  /* ORDER SUMMARY */
  .order-summary {
    padding: 28px; border: 1.5px solid rgba(0,0,0,.1);
    position: sticky; top: 90px;
  }
  .summary-title { font-size: 13px; font-weight: 800; letter-spacing: .08em; text-transform: uppercase; margin-bottom: 20px; }

  .summary-line { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; font-size: 14px; }
  .summary-line.total { font-weight: 900; font-size: 18px; padding-top: 16px; border-top: 1.5px solid rgba(0,0,0,.1); margin-top: 4px; }
  .summary-line span:first-child { color: var(--gray); font-weight: 600; }
  .summary-line.total span:first-child { color: var(--dark); }

  .free-ship { font-size: 12px; font-weight: 700; color: var(--lime); background: var(--dark); padding: 3px 8px; letter-spacing: .05em; }

  .btn-checkout {
    display: block; width: 100%; margin-top: 20px;
    padding: 16px; background: var(--lime); color: var(--dark);
    font-size: 13px; font-weight: 900; letter-spacing: .07em; text-transform: uppercase;
    border: none; cursor: pointer; text-align: center; text-decoration: none;
    transition: opacity .2s;
  }
  .btn-checkout:hover { opacity: .85; }

  .trust-row { display: flex; flex-direction: column; gap: 8px; margin-top: 20px; }
  .trust-item { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; color: var(--gray); }
  .trust-icon { font-size: 16px; }

  /* CONTINUE SHOPPING */
  .continue-link {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase;
    color: var(--dark); text-decoration: none; margin-top: 20px;
    transition: opacity .2s;
  }
  .continue-link:hover { opacity: .5; }

  /* TOAST */
  .toast {
    position: fixed; bottom: 28px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--dark); color: var(--lime); font-size: 13px; font-weight: 800;
    letter-spacing: .06em; padding: 12px 28px; z-index: 999; pointer-events: none;
    transition: transform .35s cubic-bezier(.22,1,.36,1);
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* FOOTER */
  footer {
    text-align: center; padding: 32px 24px;
    font-size: 12px; color: var(--gray);
    border-top: 1px solid rgba(0,0,0,.07); position: relative; z-index: 1;
  }
</style>
</head>
<body>
<div class="blob-tr"></div>
<div class="blob-bl"></div>

<!-- NAV -->
<nav>
  <a class="logo" href="index.html">
    <svg class="logo-icon" viewBox="0 0 32 32" fill="none">
      <circle cx="16" cy="16" r="14" fill="#0D0D1A"/>
      <path d="M16 4 C10 10, 8 14, 16 28 C24 14, 22 10, 16 4Z" fill="#C8FF00"/>
      <circle cx="16" cy="16" r="3" fill="#E5007D"/>
      <line x1="16" y1="7" x2="16" y2="25" stroke="#fff" stroke-width="1" stroke-dasharray="2 2" opacity=".4"/>
      <line x1="7" y1="16" x2="25" y2="16" stroke="#fff" stroke-width="1" stroke-dasharray="2 2" opacity=".4"/>
    </svg>
    SOAK <span class="ops">OPS</span>
  </a>
  <ul class="nav-links">
    <li><a href="index.html">Shop</a></li>
    <li><a href="index.html#categories">Categories</a></li>
    <li><a href="cart.html">Cart <span class="cart-badge" id="nav-count">0</span></a></li>
  </ul>
  <a href="index.html" class="btn-nav">Keep Shopping</a>
</nav>

<!-- PAGE -->
<div class="page-wrap">
  <h1 class="page-title">YOUR <span class="k">CART</span></h1>
  <p class="page-subtitle" id="item-count">Loading...</p>

  <div class="cart-layout" id="cart-layout">
    <!-- filled by JS -->
  </div>
</div>

<div class="toast" id="toast"></div>

<footer>
  © 2025 Soak Ops &nbsp;·&nbsp; Ships 7–12 days to U.S. &nbsp;·&nbsp; Free tracking on every order
</footer>

<script src="products.js"></script>
<script>
const CDN_URL = 'https://ae-pic-a1.aliexpress-media.com/kf/';

const SHOPIFY_DOMAIN = '0u1gd1-9z.myshopify.com';
// Maps local product id -> Shopify variant id. Empty until products are imported;
// regenerate with build-variant-map.js once the store is live, then paste here.
const VARIANT_MAP = {
  0: 46969982812335,
  1: 46969983565999,
  2: 46969983631535,
  3: 46969984254127,
  4: 46969984286895,
  5: 46969984319663,
  6: 46969984352431,
  7: 46969984942255,
  8: 46969984975023,
  9: 46969985040559,
  10: 46970002768047,
  11: 46970002800815,
  12: 46970002833583,
  13: 46970002866351,
  14: 46970002899119,
  15: 46970002931887,
  16: 46970002964655,
  17: 46970002997423,
  18: 46970003030191,
  19: 46970003062959,
  20: 46970003095727,
  21: 46970003128495,
  22: 46970003161263,
  23: 46970003194031,
  24: 46970003226799,
  25: 46970003259567,
  26: 46970003292335,
  27: 46970003325103,
  28: 46970003357871,
  29: 46970003390639,
  30: 46970003423407,
  31: 46970003456175,
  32: 46970003488943,
  33: 46970004439215,
  34: 46970004471983,
  35: 46970004504751,
  36: 46970004537519,
  37: 46970004570287,
  38: 46970004603055,
  39: 46970004635823,
  40: 46970004734127,
  41: 46970004766895,
  42: 46970004799663,
  43: 46970004832431,
  44: 46970004865199,
  45: 46970004897967,
  46: 46970004930735,
  47: 46970004963503,
  48: 46970004996271,
  49: 46970005029039,
  50: 46970005061807,
  51: 46970005094575,
  52: 46970005127343,
  53: 46970005160111,
  54: 46970005192879,
  55: 46970005225647,
  56: 46970005258415,
  57: 46970005291183,
  58: 46970005323951,
  59: 46970005356719,
};

function getCart() { return JSON.parse(localStorage.getItem('soakops-cart') || '[]'); }
function saveCart(c) { localStorage.setItem('soakops-cart', JSON.stringify(c)); }

function updateNavCount() {
  const cart = getCart();
  const total = cart.reduce((s, i) => s + i.qty, 0);
  document.getElementById('nav-count').textContent = total;
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2400);
}

function changeQty(id, delta) {
  const cart = getCart();
  const idx = cart.findIndex(i => i.id === id);
  if (idx < 0) return;
  cart[idx].qty = Math.max(1, cart[idx].qty + delta);
  saveCart(cart);
  render();
}

function removeItem(id) {
  const cart = getCart().filter(i => i.id !== id);
  saveCart(cart);
  showToast('Removed from cart');
  render();
}

function nameHtml(name) {
  return name.replace(/(\b\w+\b)$/, '<span class="k">$1</span>');
}

function render() {
  const cart = getCart();
  updateNavCount();

  const layout = document.getElementById('cart-layout');
  const countEl = document.getElementById('item-count');

  if (cart.length === 0) {
    countEl.textContent = '0 items';
    layout.innerHTML = `
      <div class="empty-cart" style="grid-column:1/-1">
        <div class="big">💧</div>
        <h2>Your cart is empty</h2>
        <p>Pick a water gun and get ready to soak.</p>
        <a class="btn-shop" href="index.html">Shop All Guns →</a>
      </div>`;
    return;
  }

  const itemCount = cart.reduce((s, i) => s + i.qty, 0);
  countEl.textContent = itemCount + ' item' + (itemCount !== 1 ? 's' : '');

  const subtotal = cart.reduce((s, i) => s + i.price * i.qty, 0);
  const shipping = 0;
  const total = subtotal + shipping;

  const itemsHtml = cart.map(item => {
    const prod = PRODUCTS.find(p => p.id === item.id);
    const imgSrc = prod ? CDN_URL + prod.img : '';
    return `
    <div class="cart-item">
      <a href="product.html?id=${item.id}">
        <img class="cart-item-img" src="${imgSrc}" alt="${item.name}" onerror="this.style.display='none'"/>
      </a>
      <div>
        <div class="cart-item-name">${nameHtml(item.name)}</div>
        <div class="cart-item-price">$${(item.price * item.qty).toFixed(2)}</div>
        <div class="qty-row">
          <button class="qty-btn" onclick="changeQty(${item.id}, -1)">−</button>
          <span class="qty-val">${item.qty}</span>
          <button class="qty-btn" onclick="changeQty(${item.id}, 1)">+</button>
        </div>
      </div>
      <button class="remove-btn" onclick="removeItem(${item.id})">Remove</button>
    </div>`;
  }).join('');

  layout.innerHTML = `
    <div>
      <div class="cart-items">${itemsHtml}</div>
      <a class="continue-link" href="index.html">← Continue Shopping</a>
    </div>
    <div class="order-summary">
      <div class="summary-title">Order Summary</div>
      <div class="summary-line"><span>Subtotal</span><span>$${subtotal.toFixed(2)}</span></div>
      <div class="summary-line"><span>Shipping</span><span class="free-ship">FREE</span></div>
      <div class="summary-line"><span>Delivery</span><span>7–12 days U.S.</span></div>
      <div class="summary-line total"><span>Total</span><span>$${total.toFixed(2)}</span></div>
      <button class="btn-checkout" onclick="checkout()">Checkout →</button>
      <div class="trust-row">
        <div class="trust-item"><span class="trust-icon">🔒</span> Secure checkout</div>
        <div class="trust-item"><span class="trust-icon">📦</span> Free tracking on every order</div>
        <div class="trust-item"><span class="trust-icon">↩️</span> 30-day easy returns</div>
      </div>
    </div>`;
}

function checkout() {
  const cart = getCart();
  if (!cart.length) return;

  // Build a Shopify cart permalink so the customer's items carry over.
  const items = cart
    .filter(i => VARIANT_MAP[i.id])
    .map(i => `${VARIANT_MAP[i.id]}:${i.qty}`);

  // Until products are imported (VARIANT_MAP empty), fall back to the store root.
  if (!items.length) {
    window.location.href = `https://${SHOPIFY_DOMAIN}/`;
    return;
  }

  window.location.href = `https://${SHOPIFY_DOMAIN}/cart/${items.join(',')}`;
}

// Handle "Buy Now" — ?buynow=ID adds item then renders
(function handleBuyNow() {
  const params = new URLSearchParams(location.search);
  const id = parseInt(params.get('buynow'));
  if (!isNaN(id)) {
    const prod = PRODUCTS.find(p => p.id === id);
    if (prod) {
      const cart = getCart();
      const idx = cart.findIndex(i => i.id === id);
      if (idx > -1) { cart[idx].qty += 1; } else { cart.push({id: prod.id, name: prod.name, price: prod.price, img: prod.img, qty: 1}); }
      saveCart(cart);
    }
    history.replaceState(null, '', 'cart.html');
  }
})();

render();
</script>
</body>
</html>
